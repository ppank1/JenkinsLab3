pipeline {
    agent any
    stages {
        stage("Cleanup") {
            steps {
                sh "docker rm -f task1-container nginx-proxy 2>/dev/null || true"
                sh "docker network rm app-network 2>/dev/null || true"
            }
        }
        stage("Setup") {
            steps {
                sh "docker network create app-network"
            }
        }
        stage("Security Scan") {
            steps {
                dir('Task1') {
                    sh "trivy fs --format json --output trivy-results.json ."
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'Task1/trivy-results.json', allowEmptyArchive: true
                }
            }
        }
        stage("Unit Test") {
            steps {
                dir('Task1') {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        sh '''
                            python3 -m venv venv
                            . venv/bin/activate
                            pip install -r test-requirements.txt
                            python -m pytest test_app.py -v --junitxml=test-results.xml
                        '''
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'Task1/test-results.xml'
                }
            }
        }
        stage("Build") {
            steps {
                dir('Task1') {
                    sh "docker build -t ppankh/flask-app ."
                }
            }
        }
        stage("Deploy") {
            steps {
                dir('Task1') {
                    sh "docker run -d --name task1-container --network app-network ppankh/flask-app"
                    sh "docker run -d -p 80:80 --name nginx-proxy --network app-network -v \$(pwd)/nginx.conf:/etc/nginx/nginx.conf:ro nginx"
                }
            }
        }
        stage("Test") {
            steps {
                sh "sleep 5"
                sh "curl -f localhost"
            }
        }
    }
    post {
        always {
            sh "rm -rf Task1/venv"
        }
        success {
            echo "Pipeline completed successfully!"
        }
        unstable {
            echo "Pipeline completed with warnings - check test results."
        }
        failure {
            echo "Pipeline failed - check logs for details."
        }
    }
}

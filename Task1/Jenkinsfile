pipeline {
    agent any
    stages {
        stage("Cleanup") {
            steps {
                sh "docker rm -f task1-container nginx-proxy 2>/dev/null || true"
                sh "docker network rm app-network 2>/dev/null || true"
            }
        }
        stage("Setup") {
            steps {
                sh "docker network create app-network"
            }
        }
        stage("Security Scan") {
            steps {
                dir('Task1') {
                    sh "trivy fs --format json --output trivy-results.json ."
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'Task1/trivy-results.json', allowEmptyArchive: true
                }
            }
        }
        stage("Unit Test") {
            steps {
                dir('Task1') {
                    sh "pip install -r requirements.txt || pip3 install -r requirements.txt"
                    sh "python -m unittest test_app -v || python3 -m unittest test_app -v"
                }
            }
        }
        stage("Build") {
            steps {
                dir('Task1') {
                    sh "docker build -t ppankh/flask-app ."
                }
            }
        }
        stage("Deploy") {
            steps {
                dir('Task1') {
                    sh "docker run -d --name task1-container --network app-network ppankh/flask-app"
                    sh "docker run -d -p 80:80 --name nginx-proxy --network app-network -v \$(pwd)/nginx.conf:/etc/nginx/nginx.conf:ro nginx"
                }
            }
        }
        stage("Test") {
            steps {
                sh "sleep 5"
                sh "curl -f localhost"
            }
        }
    }
}
